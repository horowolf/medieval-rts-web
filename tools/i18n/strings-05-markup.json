{
  "<title>RTS 原型 — 切片四：文明系統（第三段：三文明科技樹）</title>": "<title>Medieval RTS — a touch-first real-time strategy prototype</title>",
  "<button class=\"tabBtn\" id=\"tabTech\" title=\"文明科技樹（給玩家參考）\">📜</button>": "<button class=\"tabBtn\" id=\"tabTech\" title=\"Civilisation tech tree (reference)\">📜</button>",
  "<button id=\"dbgBtn\" type=\"button\" title=\"除錯：座標/路徑/移動log\">🐞 除錯</button>": "<button id=\"dbgBtn\" type=\"button\" title=\"Debug: coordinates, paths, movement log\">🐞 Debug</button>",
  "<button id=\"arenaBtn\" type=\"button\" title=\"擂台：測試對戰（平地·無經濟）\">⚔️ 擂台</button>": "<button id=\"arenaBtn\" type=\"button\" title=\"Arena: test battles on flat ground, no economy\">⚔️ Arena</button>",
  "<button id=\"mapBtn\" type=\"button\" title=\"切換地圖：陸戰圖 / 水域圖（重載）\">🌊 水域圖</button>": "<button id=\"mapBtn\" type=\"button\" title=\"Switch map (reloads)\">🌊 Map</button>",
